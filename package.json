{
  "name": "telegram-bot-llm",
  "version": "1.0.0",
  "description": "Step 2: Telegram Bot with Gemini LLM + pgvector RAG + session memory",
  "main": "dist/bot.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/bot.ts",
    "start": "node dist/bot.js",
    "ingest": "ts-node-dev --transpile-only scripts/ingest.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "grammy": "^1.30.0",
    "pg": "^8.11.3",
    "pgvector": "^0.2.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
